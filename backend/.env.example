# Backend Environment Variables Template
# Copy this file to .env and fill in with actual values

# === Database (Supabase) ===
# Get this from: https://supabase.com > Project > Settings > Database > Connection Pooling
DATABASE_URL=postgresql://postgres.xxxxx:password@aws-0-xxxxx.pooler.supabase.com:5432/postgres

# === Email Configuration (Gmail) ===
# EMAIL_USER: Your Gmail address
EMAIL_USER=your-email@gmail.com

# EMAIL_PASSWORD: Gmail App Password (not your regular password!)
# Steps: 
# 1. Enable 2FA on Gmail account
# 2. Go to myaccount.google.com > Security > App passwords
# 3. Select "Mail" and "Windows Computer"
# 4. Copy the 16-character password
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx

# === Authentication ===
# JWT_SECRET: Use a strong random string (at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# === Server Configuration ===
# PORT: Server port (3000 for local, will be overridden on Render)
PORT=3000

# NODE_ENV: Environment (development, production)
NODE_ENV=development

# === Optional: For Production ===
# Uncomment when deploying to production
# CORS_ORIGIN=https://yourdomain.com
# LOG_LEVEL=info
